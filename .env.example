# CWA Open Data API Key (required)
CWA_API_KEY=your-api-key-here

# HTTP Server Settings
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# Cache Settings
CACHE_TTL_HOURS=24

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# MCP Security Settings
# Enable DNS rebinding protection (recommended: false for Docker internal networks)
MCP_ENABLE_DNS_PROTECTION=false
